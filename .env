# AURA Configuration

# Use local Ollama (no API key needed)
MODEL_PROVIDER=local

# Alternative providers (uncomment and add key if needed)
# MODEL_PROVIDER=openrouter
# OPENROUTER_API_KEY=your_openrouter_key

# MODEL_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_key

# MODEL_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key

# Gemini API (for advanced actions like desktop automation)
# GEMINI_API_KEY=your_gemini_key

# GitHub token (optional - for code learning)
# GITHUB_TOKEN=

# NewsData API (for news tool)
# NEWSDATA_API_KEY=your_newsdata_key

# ==== MULTI-CHANNEL CONFIGURATION ====
# Get tokens from: https://core.telegram.org/bot#new-bot
# TELEGRAM_BOT_TOKEN=

# Get from: https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=

# Get from: https://api.slack.com/apps
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=